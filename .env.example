# --- Обязательные ---
# Подпись сессий (JWT) И шифрование паролей внешних БД (Database Connections,
# abkit/db_connections/crypto.py — ключ Fernet выводится из этого же секрета,
# отдельного ABKIT_DB_ENCRYPTION_KEY нет). Генерировать: openssl rand -hex 32.
# ВНИМАНИЕ: ротация этого ключа делает уже сохраненные пароли подключений к
# БД нерасшифровываемыми — прежде чем менять его, пересоздайте подключения
# (Settings > Database Connections) или временно сохраните старое значение.
ABKIT_SECRET_KEY=change-me-long-random-string
POSTGRES_PASSWORD=change-me

# --- С разумными дефолтами ---
POSTGRES_USER=abkit
POSTGRES_DB=abkit
# DATABASE_URL собирается автоматически в docker-compose.yml из POSTGRES_USER/
# POSTGRES_PASSWORD/POSTGRES_DB (docker-compose .env не раскрывает ${...}
# внутри своих же значений — задавать тут DATABASE_URL напрямую бесполезно).
# Если нужен внешний managed Postgres — переопределите переменную DATABASE_URL
# в environment: сервиса backend в docker-compose.yml.
ABKIT_PORT=8080                         # внешний порт nginx
ABKIT_LOG_LEVEL=INFO
ABKIT_LOG_FORMAT=json                   # json | text
ABKIT_SESSION_LIFETIME_HOURS=72
ABKIT_MAX_UPLOAD_MB=400
ABKIT_ALLOW_SELF_REGISTRATION=false     # как в Superset: по умолчанию учетки заводит админ

# --- Database Connections + датасеты из SQL (CLAUDE.md, "Database Connections
# + датасет-центричная модель") ---
ABKIT_SQL_MAX_ROWS=5000000              # обрезка датасета из SQL, с флагом truncated в UI
ABKIT_SQL_TIMEOUT_SEC=300               # таймаут выполнения SELECT (from-sql/refresh, не preview)

# --- Backend API (FRONTEND.md; сервисы backend/frontend в docker-compose.yml) ---
ABKIT_JOB_WORKERS=2                     # потоков ThreadPoolExecutor для design/analyze/validate (FRONTEND.md §4)
#ABKIT_COOKIE_SECURE=false               # true, только вместе с TLS-блоком в docker/nginx.conf.template (см. docker/README.md, раздел TLS) — иначе браузер Secure-cookie на голом HTTP не сохранит
#ABKIT_CORS_ORIGINS=http://localhost:5173 # ТОЛЬКО для локальной разработки фронта без Docker (vite dev server, npm run dev); не участвует в docker-compose (один origin через nginx, CORS не нужен)
#VITE_API_BASE=                         # аналогично — только для локальной разработки; в docker-compose не используется (frontend/src/api/client.ts по умолчанию ходит по относительному "/api/v1", один origin через nginx)

# --- Bootstrap первого администратора (опционально) ---
# Если заданы оба значения и таблица users пуста — entrypoint backend создаст
# первого админа автоматически при старте (без ручного docker compose exec).
# Иначе создайте его вручную: docker compose exec backend abkit-admin create-admin --email admin@co.com
#ABKIT_ADMIN_EMAIL=admin@company.com
#ABKIT_ADMIN_PASSWORD=change-me
#ABKIT_ADMIN_NAME=Admin
